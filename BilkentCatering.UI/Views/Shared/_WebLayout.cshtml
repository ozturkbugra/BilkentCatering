<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>@ViewData["Title"] - @ViewBag.SiteSettings?.CompanyName</title>
    <meta name="description" content="@ViewBag.SiteSettings?.MetaDescription">
    <meta name="keywords" content="@ViewBag.SiteSettings?.MetaKeyword">

    <!-- Favicons -->
    @if (ViewBag.SiteSettings?.Icon != null)
    {
        <link href="@ViewBag.SiteSettings.Icon" rel="icon">
    }
    @if (ViewBag.SiteSettings?.LargeIcon != null)
    {
        <link href="@ViewBag.SiteSettings.LargeIcon" rel="apple-touch-icon">
    }

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect">
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&family=Nunito:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">

    <!-- Vendor CSS -->
    <link href="~/site/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/site/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/site/assets/vendor/aos/aos.css" rel="stylesheet">
    <link href="~/site/assets/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">
    <link href="~/site/assets/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">

    <!-- Main CSS -->
    <link href="~/site/assets/css/main.css" rel="stylesheet">

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="@ViewData["BodyClass"]">

    @await Component.InvokeAsync("Header")

    <main class="main">
        @RenderBody()
    </main>

    @await Component.InvokeAsync("Footer")

    <!-- Vendor JS -->
    <script src="~/site/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/site/assets/vendor/aos/aos.js"></script>
    <script src="~/site/assets/vendor/swiper/swiper-bundle.min.js"></script>
    <script src="~/site/assets/vendor/purecounter/purecounter_vanilla.js"></script>
    <script src="~/site/assets/vendor/imagesloaded/imagesloaded.pkgd.min.js"></script>
    <script src="~/site/assets/vendor/isotope-layout/isotope.pkgd.min.js"></script>
    <script src="~/site/assets/vendor/glightbox/js/glightbox.min.js"></script>

    <!-- Main JS -->
    <script src="~/site/assets/js/main.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>