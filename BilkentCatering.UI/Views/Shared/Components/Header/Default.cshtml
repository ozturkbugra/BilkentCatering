@{
    // Controller'dan gelen BodyClass'ı kontrol ediyoruz
    var bodyClass = Context.Items["BodyClass"]?.ToString() ?? ViewData["BodyClass"]?.ToString();
    var isIndex = bodyClass == "index-page";
    
    // Index ise fixed-top, değilse sticky-top
    var headerStickyClass = isIndex ? "fixed-top" : "sticky-top";
}

<header id="header" class="header d-flex align-items-center @headerStickyClass">
    <div class="container position-relative d-flex align-items-center justify-content-between">

        <a href="/" class="logo d-flex align-items-center me-auto me-xl-0">
            @if (ViewBag.SiteSettings?.IsLogoVisible == true && ViewBag.SiteSettings?.Logo != null)
            {
                <img src="@ViewBag.SiteSettings.Logo" alt="@ViewBag.SiteSettings?.CompanyName">
            }
            @if (ViewBag.SiteSettings?.IsCompanyNameVisible == true)
            {
                <h1 class="sitename">@ViewBag.SiteSettings?.CompanyName</h1>
            }
        </a>

        <nav id="navmenu" class="navmenu">
            <ul>
                <!-- Index sayfasındaysak #hero'ya gitsin, değilse ana sayfaya yönlendirsin -->
                <li><a href="@(isIndex ? "#hero" : "/")" class="@(isIndex ? "active" : "")">Anasayfa</a></li>

                <li class="dropdown">
                    <a href="#"><span>Kurumsal</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
                    <ul>
                        <li><a href="/hakkimizda">Hakkımızda</a></li>
                        <li><a href="/politikamiz">Politikamız</a></li>
                        <li><a href="/belgeler-ve-sertifikalar">Belgeler & Sertifikalar</a></li>
                    </ul>
                </li>

                <li><a href="/hizmetlerimiz">Hizmetlerimiz</a></li>

                <li class="dropdown">
                    <a href="#"><span>Kalite</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
                    <ul>
                        <li><a href="/kalite-yonetimi">Kalite Yönetimi</a></li>
                        <li><a href="/musteri-memnuniyeti">Müşteri Memnuniyeti</a></li>
                    </ul>
                </li>

                <li class="dropdown">
                    <a href="#"><span>Medya</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
                    <ul>
                        <li><a href="/kurumsal-sunum">Kurumsal Sunum</a></li>
                        <li><a href="/tanitim-filmi">Tanıtım Filmi</a></li>
                    </ul>
                </li>

                <li><a href="/is-basvurusu">İş Başvurusu</a></li>
                <li><a href="/iletisim">İletişim</a></li>
            </ul>
            <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>

        @if (ViewBag.Contact?.WhatsApp != null)
        {
            var wpnumber = "9" +  ViewBag.Contact.WhatsApp;


            <a class="cta-btn d-flex align-items-center"
                   href="https://wa.me/@wpnumber" target="_blank"
                   style="background-color: #25D366; color: white; border: none;">
                <i class="bi bi-whatsapp me-2"></i> WhatsApp
            </a>
        }

    </div>
</header>