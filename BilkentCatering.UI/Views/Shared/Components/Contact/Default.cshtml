@using BilkentCatering.UI.Extensions
@model BilkentCatering.Entities.Concrete.Contact

<section id="contact" class="contact section">
    <div class="container section-title">
        <h2>İLETİŞİM</h2>
        <p>Bize ulaşın, kurumunuza özel yemek çözümlerimizi birlikte planlayalım.</p>
    </div>
    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="contact-main-wrapper">
            <div class="map-wrapper">
                @if (Model?.MapLink != null)
                {
                    <iframe src="@Model.MapLink" width="100%" height="100%"
                            style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                }
            </div>
            <div class="contact-content">
                <div class="contact-cards-container" data-aos="fade-up" data-aos-delay="300">
                    @if (Model?.Address != null)
                    {
                        <div class="contact-card">
                            <div class="icon-box"><i class="bi bi-geo-alt"></i></div>
                            <div class="contact-text">
                                <h4>Adres</h4>
                                <p>@Model.Address</p>
                            </div>
                        </div>
                    }
                    @if (Model?.Email != null)
                    {
                        <div class="contact-card">
                            <div class="icon-box"><i class="bi bi-envelope"></i></div>
                            <div class="contact-text">
                                <h4>E-posta</h4>
                                <p>@Model.Email</p>
                            </div>
                        </div>
                    }
                    @if (Model?.Phone != null)
                    {
                        <div class="contact-card">
                            <div class="icon-box"><i class="bi bi-telephone"></i></div>
                            <div class="contact-text">
                                <h4>Telefon</h4>
                                <p>@Model.Phone.FormatPhone()</p>
                            </div>
                        </div>
                    }
                </div>

                <div class="contact-form-container" data-aos="fade-up" data-aos-delay="400">
                    <h3>Bize Mesaj Gönderin</h3>
                    <form id="contactForm" method="post" action="/Mesaj/Gonder" class="php-email-form">
                        @Html.AntiForgeryToken()
                        <div class="row">
                            <div class="col-md-12 form-group">
                                <label>Adınız Soyadınız</label>
                                <input type="text" name="FullName" class="form-control" required>
                            </div>
                        </div>
                        <div style="display:none; visibility:hidden;">
                            <label for="WebsiteUrl">Lütfen bu alanı boş bırakın</label>
                            <input type="text" name="WebsiteUrl" id="WebsiteUrl" tabindex="-1" autocomplete="off">
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-6 form-group">
                                <label>Telefon Numaranız</label>
                                <input type="tel" name="Phone" id="contactPhone"
                                       class="form-control" placeholder="05__ ___ __ __" required>
                            </div>
                            <div class="col-md-6 form-group">
                                <label>E-Posta Adresiniz</label>
                                <input type="email" name="Email" class="form-control" required>
                            </div>
                        </div>
                        <div class="form-group mt-3">
                            <label>Konu</label>
                            <input type="text" name="Subject" class="form-control" required>
                        </div>
                        <div class="form-group mt-3">
                            <label>Mesaj</label>
                            <textarea name="Content" class="form-control" rows="5" required></textarea>
                        </div>

                        @if (TempData["ContactSuccess"] != null)
                        {
                            <div class="alert alert-success mt-3">@TempData["ContactSuccess"]</div>
                        }
                        @if (TempData["ContactError"] != null)
                        {
                            <div class="alert alert-danger mt-3">@TempData["ContactError"]</div>
                        }

                        <div class="form-submit mt-3">
                            <button type="submit" id="submitBtn">Gönder</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://unpkg.com/imask"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
    const phoneEl = document.getElementById('contactPhone');
    if (phoneEl) {
    IMask(phoneEl, {
    mask: '0000 000 00 00',
    lazy: false,
    placeholderChar: '_'
    });
    }
    });
</script>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
    
    // Telefon maskesi kodunuz aynen kalabilir
    const phoneEl = document.getElementById('contactPhone');
    if (phoneEl) {
    IMask(phoneEl, {
    mask: '0000 000 00 00',
    lazy: false,
    placeholderChar: '_'
    });
    }

    // --- AJAX İLE FORM GÖNDERME İŞLEMİ ---
    const contactForm = document.getElementById('contactForm');
    
    if (contactForm) {
    contactForm.addEventListener('submit', function (e) {
    e.preventDefault(); // Formun normal şekilde gönderilip sayfayı yenilemesini ENGELLER!

    const submitBtn = document.getElementById('submitBtn');
    const originalBtnText = submitBtn.innerText;
            
    // Kullanıcı butona birden fazla kez tıklamasın diye butonu kilitliyoruz
    submitBtn.disabled = true;
    submitBtn.innerText = "Gönderiliyor...";

    // Form verilerini otomatik topla
    const formData = new FormData(contactForm);

    // Arka planda Controller'a istek at
    fetch(contactForm.action, {
    method: 'POST',
    body: formData
    })
    .then(response => response.json())
    .then(data => {
    if (data.success) {
    // Başarılıysa SweetAlert göster
    Swal.fire({
    icon: 'success',
    title: 'Harika!',
    text: data.message,
    confirmButtonColor: '#28a745',
    confirmButtonText: 'Tamam'
    });
    contactForm.reset(); // Formun içini temizle
    } else {
    // Controller'dan hata dönerse
    Swal.fire({
    icon: 'error',
    title: 'Oops...',
    text: data.message,
    confirmButtonColor: '#d33',
    confirmButtonText: 'Tekrar Dene'
    });
    }
    })
    .catch(error => {
    // Sunucu çökmesi veya ağ hatası durumunda
    Swal.fire({
    icon: 'error',
    title: 'Bağlantı Hatası',
    text: 'Sunucu ile iletişim kurulamadı. Lütfen daha sonra tekrar deneyin.',
    confirmButtonColor: '#d33',
    confirmButtonText: 'Tamam'
    });
    })
    .finally(() => {
    // İşlem bitince (başarılı veya başarısız) butonu eski haline getir
    submitBtn.disabled = false;
    submitBtn.innerText = originalBtnText;
    });
    });
    }
    });
</script>