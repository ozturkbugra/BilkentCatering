@model List<Service>

<section id="portfolio" class="portfolio section">
    <div class="container section-title">
        <h2>Hizmetlerimiz</h2>
        <p>İhtiyacınız olan lezzeti, günün her anında ayrıcalıklı bir servis anlayışıyla sunuyoruz.</p>
    </div>
    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="isotope-layout" data-default-filter="*" data-layout="masonry" data-sort="original-order">
            <div class="row gy-4 isotope-container" data-aos="fade-up" data-aos-delay="300">
                @if (Model != null && Model.Any())
                {
                    foreach (var service in Model)
                    {
                        <div class="col-lg-4 col-md-6 portfolio-item isotope-item">
                            <div class="portfolio-card">
                                <div class="portfolio-img">
                                    <img src="@service.ImageUrl" alt="@service.Title" class="img-fluid">
                                    <div class="portfolio-overlay">
                                        <a href="@service.ImageUrl" class="glightbox portfolio-lightbox">
                                            <i class="bi bi-arrows-fullscreen"></i>
                                        </a>
                                    </div>
                                </div>
                                <div class="portfolio-info">
                                    <h4>@service.Title</h4>
                                    <p>@service.Description</p>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</section>