@model CorporatePresentation
@{
    ViewData["Title"] = "Kurumsal Sunum";
    Layout = "~/Views/Shared/_WebLayout.cshtml";
}

@await Component.InvokeAsync("PageTitle", new { @title = "Kurumsal Sunum" })

<section id="corporate-presentation" class="presentation section">

    <div class="container section-title" data-aos="fade-up">
        <h2>Kurumsal Sunum</h2>
        <p>Şirket vizyonumuz, stratejik hedeflerimiz ve kurumsal yapımız hakkında detaylı bilgilere buradan ulaşabilirsiniz.</p>
    </div>
      
    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row justify-content-center">
            <div class="col-lg-12">
              
                <div class="pdf-viewer-wrapper">
                    <div class="pdf-toolbar">
                        <div class="dots">
                            <span></span><span></span><span></span>
                        </div>
                        <div class="pdf-title">kurumsal-sunum-2026.pdf</div>
                        <div class="pdf-actions">
                            <a href="@Model.PdfLink" download title="Dosyayı İndir">
                                <i class="bi bi-download"></i>
                            </a>
                        </div>
                    </div>
                
                    <div class="pdf-content">
                        <iframe src="@Model.PdfLink" width="100%" height="800px" style="border: none;"></iframe>
                    </div>
                </div>
      
                <div class="d-lg-none text-center mt-4">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i> PDF görüntüleyici mobilde sınırlı olabilir.
                    </div>
                    <a href="@Model.PdfLink" class="btn btn-primary w-100 py-3" target="_blank">
                        <i class="bi bi-file-earmark-pdf"></i> Sunumu Tam Ekran Aç
                    </a>
                </div>
      
            </div>
        </div>
    </div>
      
</section>