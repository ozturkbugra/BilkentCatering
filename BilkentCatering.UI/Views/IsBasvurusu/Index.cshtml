
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_WebLayout.cshtml";
}

@await Component.InvokeAsync("PageTitle", new { @title = "İş Başvurusu" })


<section id="career-application" class="contact section">
    <div class="container section-title" data-aos="fade-up">
        <h2>İŞ BAŞVURUSU</h2>
        <p>
            Bilkent Kurumsal ailesine katılmak ve kariyerinizi lezzet dolu bir gelecekle inşa etmek için formu
            doldurabilirsiniz.
        </p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="contact-form-container career-form" data-aos="fade-up" data-aos-delay="200">
                    <h3 class="mb-4">Başvuru Formu</h3>

                    <form action="#" method="post" class="php-email-form" enctype="multipart/form-data">
                        <div class="row gy-4">

                            <div class="col-md-6 form-group">
                                <label for="name" class="form-label">Adınız Soyadınız</label>
                                <input type="text" name="name" class="form-control" id="name" placeholder="Örn: Ahmet Yılmaz"
                                       required="">
                            </div>

                            <div class="col-md-6 form-group">
                                <label for="email" class="form-label">E-posta Adresiniz</label>
                                <input type="email" class="form-control" name="email" id="email" placeholder="email@ornek.com"
                                       required="">
                            </div>

                            <div class="col-md-6 form-group">
                                <label for="phone" class="form-label">Telefon Numaranız</label>
                                <input type="tel" class="form-control" name="phone" id="phone" placeholder="05xx xxx xx xx"
                                       required="">
                            </div>

                            <div class="col-md-6 form-group">
                                <label for="position" class="form-label">Başvurulan Pozisyon</label>
                                <select class="form-select form-control" name="position" id="position" required>
                                    <option value="" selected disabled>Pozisyon Seçiniz...</option>
                                    <option value="asci">Usta Aşçı</option>
                                    <option value="asci-yardimcisi">Aşçı Yardımcısı</option>
                                    <option value="sofor">Şoför (Sevkiyat Personeli)</option>
                                    <option value="garson">Servis Elemanı / Garson</option>
                                    <option value="gida-muhendisi">Gıda Mühendisi / Teknikeri</option>
                                    <option value="bulasikci">Bulaşıkçı / Meydancı</option>
                                    <option value="ofis">Ofis / İdari İşler</option>
                                </select>
                            </div>

                            <div class="col-md-12 form-group">
                                <label for="experience" class="form-label">İlgili Alandaki Deneyim Süreniz</label>
                                <select class="form-select form-control" name="experience" id="experience">
                                    <option value="0-1">0 - 1 Yıl (Yeni Başlayan)</option>
                                    <option value="1-3">1 - 3 Yıl</option>
                                    <option value="3-5">3 - 5 Yıl</option>
                                    <option value="5+">5 Yıldan Fazla</option>
                                </select>
                            </div>

                           

                            <div class="col-md-12 form-group">
                                <label for="message" class="form-label">Eklemek İstedikleriniz / Ön Yazı</label>
                                <textarea class="form-control" name="message" rows="4"
                                          placeholder="Kendinizden kısaca bahsedin..."></textarea>
                            </div>

                            <div class="col-md-12 text-center">
                                <div class="loading">Başvurunuz iletiliyor...</div>
                                <div class="error-message"></div>
                                <div class="sent-message">
                                    İş başvurunuz başarıyla alınmıştır. İnsan kaynakları departmanımız sizinle
                                    iletişime geçecektir.
                                </div>

                                <div class="form-submit">
                                    <button type="submit" class="w-100">Başvuruyu Tamamla</button>
                                </div>
                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <script src="https://unpkg.com/imask"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
        const phoneElement = document.getElementById('phone');

        if (phoneElement) {
        const maskOptions = {
        mask: '0000 000 00 00',
        lazy: false, // Kullanıcı tıklayınca formatın iskeletini (____ ___ __ __) gösterir
        placeholderChar: '_'
        };

        const mask = IMask(phoneElement, maskOptions);

        // Form gönderilmeden önce kontrol yapmak istersen:
        // mask.unmaskedValue ile sadece rakamları alabilirsin (Örn: 05555555555)
        }
        });
    </script>
</section>