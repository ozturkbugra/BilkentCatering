@{
    ViewData["Title"] = "İş Başvurusu";
    Layout = "~/Views/Shared/_WebLayout.cshtml";
}

@await Component.InvokeAsync("PageTitle", new { @title = "İş Başvurusu" })

<section id="career-application" class="contact section">
    <div class="container section-title" data-aos="fade-up">
        <h2>İŞ BAŞVURUSU</h2>
        <p>
            Bilkent Kurumsal ailesine katılmak ve kariyerinizi lezzet dolu bir gelecekle inşa etmek için formu
            doldurabilirsiniz.
        </p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="contact-form-container career-form" data-aos="fade-up" data-aos-delay="200">
                    <h3 class="mb-4">Başvuru Formu</h3>

                    <form id="jobApplicationForm" action="/IsBasvurusu/BasvuruYap" method="post" class="php-email-form">
                        @Html.AntiForgeryToken()
                        <div class="row gy-4">

                            <div class="col-md-6 form-group">
                                <label for="name" class="form-label">Adınız Soyadınız</label>
                                <input type="text" name="FullName" class="form-control" id="name" placeholder="Örn: Ahmet Yılmaz" required>
                            </div>

                            <div style="display:none; visibility:hidden;">
                                <label for="WebsiteUrl">Lütfen bu alanı boş bırakın</label>
                                <input type="text" name="WebsiteUrl" id="WebsiteUrl" tabindex="-1" autocomplete="off">
                            </div>

                            <div class="col-md-6 form-group">
                                <label for="email" class="form-label">E-posta Adresiniz</label>
                                <input type="email" class="form-control" name="Email" id="email" placeholder="email@ornek.com" required>
                            </div>

                            <div class="col-md-6 form-group">
                                <label for="phone" class="form-label">Telefon Numaranız</label>
                                <input type="tel" class="form-control" name="Phone" id="phone" placeholder="05xx xxx xx xx" required>
                            </div>

                            <div class="col-md-6 form-group">
                                <label for="position" class="form-label">Başvurulan Pozisyon</label>
                                <select class="form-select form-control" name="Position" id="position" required>
                                    <option value="" selected disabled>Pozisyon Seçiniz...</option>
                                    <option value="Usta Aşçı">Usta Aşçı</option>
                                    <option value="Aşçı Yardımcısı">Aşçı Yardımcısı</option>
                                    <option value="Şoför (Sevkiyat Personeli)">Şoför (Sevkiyat Personeli)</option>
                                    <option value="Servis Elemanı / Garson">Servis Elemanı / Garson</option>
                                    <option value="Gıda Mühendisi / Teknikeri">Gıda Mühendisi / Teknikeri</option>
                                    <option value="Bulaşıkçı / Meydancı">Bulaşıkçı / Meydancı</option>
                                    <option value="Ofis / İdari İşler">Ofis / İdari İşler</option>
                                </select>
                            </div>

                            <div class="col-md-12 form-group">
                                <label for="experience" class="form-label">İlgili Alandaki Deneyim Süreniz</label>
                                <select class="form-select form-control" name="ExperienceYear" id="experience" required>
                                    <option value="0 - 1 Yıl (Yeni Başlayan)">0 - 1 Yıl (Yeni Başlayan)</option>
                                    <option value="1 - 3 Yıl">1 - 3 Yıl</option>
                                    <option value="3 - 5 Yıl">3 - 5 Yıl</option>
                                    <option value="5 Yıldan Fazla">5 Yıldan Fazla</option>
                                </select>
                            </div>

                            <div class="col-md-12 form-group">
                                <label for="message" class="form-label">Eklemek İstedikleriniz / Ön Yazı</label>
                                <textarea class="form-control" name="Description" rows="4" placeholder="Kendinizden kısaca bahsedin..."></textarea>
                            </div>

                            <div class="col-md-12 text-center">
                                <div class="form-submit mt-3">
                                    <button type="submit" id="submitBtn" class="w-100">Başvuruyu Tamamla</button>
                                </div>
                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>



<script src="https://unpkg.com/imask"></script>
<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        
    // Telefon Maskesi
    const phoneElement = document.getElementById('phone');
    if (phoneElement) {
    IMask(phoneElement, {
    mask: '0000 000 00 00',
    lazy: false,
    placeholderChar: '_'
    });
    }

    // --- AJAX İLE FORM GÖNDERME İŞLEMİ ---
    const jobForm = document.getElementById('jobApplicationForm');
        
    if (jobForm) {
    jobForm.addEventListener('submit', function (e) {
    e.preventDefault(); // Sayfa yenilemesini engelle

    const submitBtn = document.getElementById('submitBtn');
    const originalBtnText = submitBtn.innerText;
                
    // Butonu kilitle
    submitBtn.disabled = true;
    submitBtn.innerText = "Gönderiliyor...";

    const formData = new FormData(jobForm);

    fetch(jobForm.action, {
    method: 'POST',
    body: formData
    })
    .then(response => response.json())
    .then(data => {
    if (data.success) {
    Swal.fire({
    icon: 'success',
    title: 'Başarılı!',
    text: data.message,
    confirmButtonColor: '#28a745',
    confirmButtonText: 'Tamam'
    });
    jobForm.reset(); // Formu temizle
    } else {
    Swal.fire({
    icon: 'warning',
    title: 'Uyarı',
    text: data.message,
    confirmButtonColor: '#f39c12',
    confirmButtonText: 'Tamam'
    });
    }
    })
    .catch(error => {
    Swal.fire({
    icon: 'error',
    title: 'Bağlantı Hatası',
    text: 'Sunucu ile iletişim kurulamadı. Lütfen daha sonra tekrar deneyin.',
    confirmButtonColor: '#d33',
    confirmButtonText: 'Tamam'
    });
    })
    .finally(() => {
    // Butonu eski haline getir
    submitBtn.disabled = false;
    submitBtn.innerText = originalBtnText;
    });
    });
    }
    });
</script>