@model IntroductionVideo
@{
    ViewData["Title"] = "Tanıtım Filmi";
    Layout = "~/Views/Shared/_WebLayout.cshtml";
}

@await Component.InvokeAsync("PageTitle", new { @title = "Tanıtım Filmi" })

<section id="corporate-presentation" class="presentation section">
    <link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
    <script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>

    <div class="container section-title" data-aos="fade-up">
        <h2>Tanıtım FİLMİ</h2>
        <p>@Model.Description</p>
    </div>

    <div class="container" data-aos="zoom-in" data-aos-delay="100">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="video-player-wrapper">
                    <div id="player" data-plyr-provider="youtube" data-plyr-embed-id="@Model.VideoUrl">
                    </div>
                </div>


            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
        const player = new Plyr('#player', {
        controls: [
        'play-large',
        'play',
        'progress',
        'current-time',
        'mute',
        'volume',
        'fullscreen'
        ],
        // YouTube logosunu ve ilgili videoları gizlemek için ek ayarlar
        youtube: {
        noCookie: true,
        rel: 0,
        showinfo: 0,
        iv_load_policy: 3,
        modestbranding: 1
        }
        });

                   
        });
    </script>
</section>