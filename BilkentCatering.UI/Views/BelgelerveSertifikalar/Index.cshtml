@model List<CertificateAndDocument>
@{
    ViewData["Title"] = "Belgeler ve Sertifikalarımız";
    Layout = "~/Views/Shared/_WebLayout.cshtml";
}

@await Component.InvokeAsync("PageTitle", new { @title = "Belgeler ve Sertifikalarımız" })


<section id="certificates" class="certificates section">

    <div class="container section-title" data-aos="fade-up">
        <h2>Belgeler & SERTİFİKALAR </h2>
        <p>Kalite standartlarımızı ve yetkinliklerimizi temsil eden güncel belgelerimiz.</p>
    </div>
      
    <div class="container">
        <div class="row gy-4">
      
            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                    <div class="cert-item">
                        <div class="cert-icon">
                            <i class="bi bi-file-earmark-pdf"></i>
                        </div>
                        <h4>@item.Title</h4>
                        <p>@item.Description</p>
                        <div class="cert-links">
                            <a href="@item.PdfLink" target="_blank" class="btn-view">
                                <i class="bi bi-eye"></i> Belgeyi Görüntüle
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
      
</section>