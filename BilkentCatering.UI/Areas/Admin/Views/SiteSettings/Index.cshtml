@model SiteSettings

@{
    ViewData["Title"] = "Site Ayarları";
    ViewData["Breadcrumb"] = "Site Ayarları";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">Site Ayarları</h5>
    </div>
    <div class="card-body">
        <form method="post" action="/Admin/SiteSettings/Save" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="row g-4">

                <!-- Firma Adı -->
                <div class="col-md-6">
                    <label class="form-label">Firma Adı</label>
                    <input type="text" name="CompanyName" class="form-control"
                           value="@Model?.CompanyName" placeholder="Firma adını girin">
                </div>

                <!-- Slogan -->
                <div class="col-md-6">
                    <label class="form-label">Slogan</label>
                    <input type="text" name="Slogan" class="form-control"
                           value="@Model?.Slogan" placeholder="Slogan girin">
                </div>

                <!-- Açıklama -->
                <div class="col-md-12">
                    <label class="form-label">Açıklama</label>
                    <textarea name="Description" class="form-control" rows="3"
                              placeholder="Kısa açıklama girin">@Model?.Description</textarea>
                </div>

                <!-- SEO Title -->
                <div class="col-md-6">
                    <label class="form-label">SEO Title</label>
                    <input type="text" name="Title" class="form-control"
                           value="@Model?.Title" placeholder="Sayfa başlığı">
                </div>

                <!-- SEO Meta Description -->
                <div class="col-md-6">
                    <label class="form-label">Meta Description</label>
                    <input type="text" name="MetaDescription" class="form-control"
                           value="@Model?.MetaDescription" placeholder="Meta açıklama">
                </div>

                <!-- SEO Keywords -->
                <div class="col-md-12">
                    <label class="form-label">Meta Keywords</label>
                    <input type="text" name="MetaKeyword" class="form-control"
                           value="@Model?.MetaKeyword" placeholder="Anahtar kelimeler, virgülle ayırın">
                </div>

                <!-- Logo -->
                <div class="col-md-4">
                    <label class="form-label">Logo</label>
                    <div class="upload-dropzone upload-dropzone-image" id="logoDropzone">
                        <input type="file" name="logoFile" id="logoFile" accept="image/*" hidden>
                        <div class="upload-dropzone-content">
                            <div class="upload-dropzone-icon">
                                <i class="bi bi-image"></i>
                            </div>
                            <h5 class="upload-dropzone-title">Logo yükle</h5>
                            <p class="upload-dropzone-text">PNG, JPG, WebP</p>
                        </div>
                    </div>
                    <div class="upload-image-preview mt-2" id="logoPreview">
                        @if (Model?.Logo != null)
                        {
                            <img src="@Model.Logo" alt="Logo" class="img-thumbnail" style="height:80px;">
                        }
                    </div>
                </div>

                <!-- Icon -->
                <div class="col-md-4">
                    <label class="form-label">Icon (Favicon)</label>
                    <div class="upload-dropzone upload-dropzone-image" id="iconDropzone">
                        <input type="file" name="iconFile" id="iconFile" accept="image/*" hidden>
                        <div class="upload-dropzone-content">
                            <div class="upload-dropzone-icon">
                                <i class="bi bi-image"></i>
                            </div>
                            <h5 class="upload-dropzone-title">Icon yükle</h5>
                            <p class="upload-dropzone-text">PNG, ICO, WebP</p>
                        </div>
                    </div>
                    <div class="upload-image-preview mt-2" id="iconPreview">
                        @if (Model?.Icon != null)
                        {
                            <img src="@Model.Icon" alt="Icon" class="img-thumbnail" style="height:80px;">
                        }
                    </div>
                </div>

                <!-- Large Icon -->
                <div class="col-md-4">
                    <label class="form-label">Büyük Icon</label>
                    <div class="upload-dropzone upload-dropzone-image" id="largeIconDropzone">
                        <input type="file" name="largeIconFile" id="largeIconFile" accept="image/*" hidden>
                        <div class="upload-dropzone-content">
                            <div class="upload-dropzone-icon">
                                <i class="bi bi-image"></i>
                            </div>
                            <h5 class="upload-dropzone-title">Büyük Icon yükle</h5>
                            <p class="upload-dropzone-text">PNG, JPG, WebP</p>
                        </div>
                    </div>
                    <div class="upload-image-preview mt-2" id="largeIconPreview">
                        @if (Model?.LargeIcon != null)
                        {
                            <img src="@Model.LargeIcon" alt="Large Icon" class="img-thumbnail" style="height:80px;">
                        }
                    </div>
                </div>

                <!-- Logo Görünsün mü -->
                <div class="col-md-6">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsLogoVisible"
                               id="isLogoVisible" value="true"
                        @(Model?.IsLogoVisible == true ? "checked" : "")>
                        <label class="form-check-label" for="isLogoVisible">Logo Görünsün</label>
                    </div>
                </div>

                <!-- Firma Adı Görünsün mü -->
                <div class="col-md-6">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsCompanyNameVisible"
                               id="isCompanyNameVisible" value="true"
                        @(Model?.IsCompanyNameVisible == true ? "checked" : "")>
                        <label class="form-check-label" for="isCompanyNameVisible">Firma Adı Görünsün</label>
                    </div>
                </div>

                <!-- Kaydet -->
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-2"></i>Kaydet
                    </button>
                </div>

            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Her dropzone için preview
        function setupDropzone(dropzoneId, inputId, previewId) {
            const dropzone = document.getElementById(dropzoneId);
            const input = document.getElementById(inputId);
            const preview = document.getElementById(previewId);

            dropzone.addEventListener('click', () => input.click());

            dropzone.addEventListener('dragover', e => {
                e.preventDefault();
                dropzone.classList.add('dragover');
            });

            dropzone.addEventListener('dragleave', () => {
                dropzone.classList.remove('dragover');
            });

            dropzone.addEventListener('drop', e => {
                e.preventDefault();
                dropzone.classList.remove('dragover');
                const file = e.dataTransfer.files[0];
                if (file) showPreview(file, preview);
                const dt = new DataTransfer();
                dt.items.add(file);
                input.files = dt.files;
            });

            input.addEventListener('change', () => {
                if (input.files[0]) showPreview(input.files[0], preview);
            });
        }

        function showPreview(file, preview) {
            const reader = new FileReader();
            reader.onload = e => {
                preview.innerHTML = `<img src="${e.target.result}" class="img-thumbnail" style="height:80px;">`;
            };
            reader.readAsDataURL(file);
        }

        setupDropzone('logoDropzone', 'logoFile', 'logoPreview');
        setupDropzone('iconDropzone', 'iconFile', 'iconPreview');
        setupDropzone('largeIconDropzone', 'largeIconFile', 'largeIconPreview');
    </script>
}