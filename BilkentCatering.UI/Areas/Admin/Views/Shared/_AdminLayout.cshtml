<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Bilkent Catering Admin</title>

    <link href="~/admin/assets/img/favicon.png" rel="icon">
    <link href="~/admin/assets/img/apple-touch-icon.png" rel="apple-touch-icon">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link href="~/admin/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/admin/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/admin/assets/vendor/remixicon/remixicon.css" rel="stylesheet">
    <link href="~/admin/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
    <link href="~/admin/assets/vendor/phosphor-icons/phosphor-icons.css" rel="stylesheet">
    <link href="~/admin/assets/vendor/simple-datatables/style.css" rel="stylesheet">
    <link href="~/admin/assets/vendor/quill/quill.snow.css" rel="stylesheet">

    <link href="~/admin/assets/css/main.css" rel="stylesheet">

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header class="header">
        <div class="header-left">
            <a href="/Admin/Dashboard" class="header-logo">
                <img src="~/admin/assets/img/logo.webp" alt="Bilkent Catering">
                <span>Bilkent Catering</span>
            </a>
            <button class="sidebar-toggle" title="Toggle Sidebar">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <div class="header-search">
            <div class="search-form">
                <i class="bi bi-search search-icon"></i>
                <input type="search" id="headerSearch" placeholder="Sayfa ara..." autocomplete="off">
            </div>
        </div>

        <div class="header-right">
            <div class="header-actions-desktop">
                <div class="header-action-wrap">
                    <a href="/Admin/Message" class="header-action" title="Mesajlar">
                        <i class="bi bi-envelope"></i>
                    </a>
                </div>
                <div class="header-action-wrap">
                    <a href="/Admin/JobApplication" class="header-action" title="İş Başvuruları">
                        <i class="bi bi-person-lines-fill"></i>
                    </a>
                </div>
                <!-- Tema Toggle -->
                <div class="header-action-wrap">
                    <button class="header-action theme-toggle" id="themeToggle" title="Tema Değiştir">
                        <i class="bi bi-moon icon-dark"></i>
                        <i class="bi bi-sun icon-light"></i>
                    </button>
                </div>

                <span class="header-divider"></span>

                <div class="header-action-wrap dropdown user-dropdown">
                    <button class="dropdown-toggle user-trigger" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="user-brief">
                            <span class="user-name">@User.Identity.Name</span>
                            <span class="user-role">Administrator</span>
                        </div>
                        <i class="bi bi-chevron-down user-chevron"></i>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end user-menu">
                        <div class="user-menu-footer">
                            <a class="user-menu-logout" href="/Admin/Auth/Logout">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>Çıkış Yap</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="header-actions-mobile">
                <button class="header-action mobile-menu-toggle">
                    <i class="bi bi-three-dots-vertical"></i>
                </button>
            </div>
        </div>
    </header>

    <aside class="sidebar">
        <div class="sidebar-header">
            <a href="/Admin/Dashboard" class="sidebar-logo">
                <span class="sidebar-logo-text">Bilkent Catering</span>
            </a>
            <button class="sidebar-close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <nav class="sidebar-nav">
            <ul class="nav-menu" id="sidebarMenu">

                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Dashboard">
                        <span class="nav-icon"><i class="bi bi-speedometer2"></i></span>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </li>

                <li class="nav-heading"><span>Site Yönetimi</span></li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/SiteSettings">
                        <span class="nav-icon"><i class="bi bi-gear"></i></span>
                        <span class="nav-text">Site Ayarları</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/SiteImage">
                        <span class="nav-icon"><i class="bi bi-images"></i></span>
                        <span class="nav-text">Site Resimleri</span>
                    </a>
                </li>

                <li class="nav-heading"><span>İçerik Yönetimi</span></li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/AboutUs">
                        <span class="nav-icon"><i class="bi bi-info-circle"></i></span>
                        <span class="nav-text">Hakkımızda</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Services">
                        <span class="nav-icon"><i class="bi bi-briefcase"></i></span>
                        <span class="nav-text">Hizmetler</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Counter">
                        <span class="nav-icon"><i class="bi bi-123"></i></span>
                        <span class="nav-text">Sayaç</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Policy">
                        <span class="nav-icon"><i class="bi bi-shield-check"></i></span>
                        <span class="nav-text">Politikamız</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/CertificateAndDocument">
                        <span class="nav-icon"><i class="bi bi-file-earmark-text"></i></span>
                        <span class="nav-text">Belgeler & Sertifikalar</span>
                    </a>
                </li>

                <li class="nav-heading"><span>Kalite</span></li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/QualityManagement">
                        <span class="nav-icon"><i class="bi bi-award"></i></span>
                        <span class="nav-text">Kalite Yönetimi</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/CustomerSatisfaction">
                        <span class="nav-icon"><i class="bi bi-emoji-smile"></i></span>
                        <span class="nav-text">Müşteri Memnuniyeti</span>
                    </a>
                </li>

                <li class="nav-heading"><span>Medya</span></li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/CorporatePresentation">
                        <span class="nav-icon"><i class="bi bi-file-earmark-slides"></i></span>
                        <span class="nav-text">Kurumsal Sunum</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/IntroductionVideo">
                        <span class="nav-icon"><i class="bi bi-camera-video"></i></span>
                        <span class="nav-text">Tanıtım Filmi</span>
                    </a>
                </li>

                <li class="nav-heading"><span>İletişim</span></li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Contact">
                        <span class="nav-icon"><i class="bi bi-geo-alt"></i></span>
                        <span class="nav-text">İletişim Bilgileri</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Message">
                        <span class="nav-icon"><i class="bi bi-envelope"></i></span>
                        <span class="nav-text">Mesajlar</span>
                    </a>
                </li>

                <li class="nav-heading"><span>İnsan Kaynakları</span></li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/JobApplication">
                        <span class="nav-icon"><i class="bi bi-person-lines-fill"></i></span>
                        <span class="nav-text">İş Başvuruları</span>
                    </a>
                </li>

                <li class="nav-heading"><span>Sistem</span></li>
                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Admin">
                        <span class="nav-icon"><i class="bi bi-person-gear"></i></span>
                        <span class="nav-text">Admin Kullanıcıları</span>
                    </a>
                </li>

            </ul>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-footer-user">
                <div class="sidebar-footer-info">
                    <div class="sidebar-footer-name">@User.Identity.Name</div>
                    <div class="sidebar-footer-role">Administrator</div>
                </div>
                <div class="sidebar-footer-actions">
                    <a href="/Admin/Auth/Logout" class="sidebar-footer-action sidebar-footer-logout" title="Çıkış Yap">
                        <i class="bi bi-box-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </aside>

    <div class="sidebar-overlay"></div>

    <main class="main">
        <div class="main-content">
            @if (ViewData["Breadcrumb"] != null)
            {
                <div class="page-header">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/Admin/Dashboard">Ana Sayfa</a></li>
                            <li class="breadcrumb-item active">@ViewData["Breadcrumb"]</li>
                        </ol>
                    </nav>
                </div>
            }

            @RenderBody()
        </div>

        <footer class="footer">
            <div class="footer-content text-center">
                <div class="footer-copyright">
                    &copy; @DateTime.Now.Year <strong>Bilkent Catering</strong>. Tüm Hakları Saklıdır.
                </div>
            </div>
        </footer>
    </main>

    <script src="~/admin/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/admin/assets/vendor/simple-datatables/simple-datatables.js"></script>
    <script src="~/admin/assets/vendor/quill/quill.js"></script>

    <script src="~/admin/assets/js/theme.js"></script>
    <script src="~/admin/assets/js/main.js"></script>

    <script>
            document.getElementById('headerSearch').addEventListener('input', function () {
                const query = this.value.toLowerCase();
                const items = document.querySelectorAll('.nav-item');
                const headings = document.querySelectorAll('.nav-heading');

                if (query === '') {
                    items.forEach(item => item.style.display = '');
                    headings.forEach(heading => heading.style.display = '');
                    return;
                }

                items.forEach(item => {
                    const text = item.querySelector('.nav-text') ? item.querySelector('.nav-text').textContent.toLowerCase() : '';
                    item.style.display = text.includes(query) ? '' : 'none';
                });

                headings.forEach(heading => {
                    let next = heading.nextElementSibling;
                    let hasVisible = false;
                    while (next && !next.classList.contains('nav-heading')) {
                        if (next.style.display !== 'none') hasVisible = true;
                        next = next.nextElementSibling;
                    }
                    heading.style.display = hasVisible ? '' : 'none';
                });

                            // Tema Toggle - localStorage'da sakla
            const themeToggle = document.getElementById('themeToggle');
            const html = document.documentElement;

            // Sayfa açılınca kayıtlı temayı uygula
            const savedTheme = localStorage.getItem('theme') || 'dark';
            html.setAttribute('data-bs-theme', savedTheme);

            themeToggle.addEventListener('click', function () {
                const current = html.getAttribute('data-bs-theme');
                const next = current === 'dark' ? 'light' : 'dark';
                html.setAttribute('data-bs-theme', next);
                localStorage.setItem('theme', next);
            });
            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>